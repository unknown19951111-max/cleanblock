{
  "manifest_version": 3,
  "name": "CleanBlock",
  "version": "0.1.0",
  "description": "Privacy-preserving content blocker with signed rule updates, local-only stats, and user-controlled exceptions.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "alarms"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "core_ads",
        "enabled": true,
        "path": "rules/static/core-ads.json"
      },
      {
        "id": "privacy_trackers",
        "enabled": true,
        "path": "rules/static/privacy-trackers.json"
      },
      {
        "id": "annoyances",
        "enabled": true,
        "path": "rules/static/annoyances.json"
      }
    ]
  },
  "minimum_chrome_version": "111"
}
